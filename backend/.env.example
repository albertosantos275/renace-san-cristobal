# Copy to .env for local dev. On Railway, set these as service Variables instead.

# Local dev uses a file in the prisma folder. In production (Railway) point this
# at the mounted volume, e.g.  file:/data/prod.db
DATABASE_URL="file:./dev.db"

# CHANGE THIS to a long random string in production.
JWT_SECRET="change-me-to-a-long-random-secret"

PORT=3001
NODE_ENV=development

# Set to "true" only if you want the 150 demo citizens seeded (local testing).
# Leave unset/false in production so the real counter starts at 0.
SEED_DEMO=false
